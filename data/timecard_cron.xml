<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         === HUMAN ===
         The scheduled jobs behind the emails: send post-shift cards, send the
         scheduled card, check for missed clock-outs, and approval reminders.
         === AI AGENT ===
         ir.cron records (noupdate=1) calling elksattendance.timecard.cron methods.
         Cadence lives here; the logic lives in models/timecard_cron.py.
         ===================================================================== -->
    <data noupdate="1">

        <!-- Every 5 minutes: send queued post-shift timecard emails whose
             delay window (default 5 min after clock-out) has elapsed, so
             tips entered at the kiosk are included. -->
        <record id="ir_cron_post_shift_email" model="ir.cron">
            <field name="name">Attendance: Send Post-Shift Timecard Emails</field>
            <field name="model_id" ref="model_elksattendance_timecard_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_post_shift_emails()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="nextcall">2026-05-02 06:00:00</field>
            <field name="active" eval="True"/>
            <field name="priority">45</field>
        </record>

        <!-- Archive old pay periods (silent). DISABLED by default: the one-time
             backlog cleanup is done by the 19.0.5.0 migration, and the approver
             page already defaults to the current period, so no nightly job is
             needed. Left here (inactive) so it can be switched on in Settings ->
             Technical -> Scheduled Actions if ongoing auto-archiving is ever
             wanted. Its logic (_elks_close_old) keeps a full period of grace so
             it can't archive the period still awaiting approval. -->
        <record id="ir_cron_close_old_periods" model="ir.cron">
            <field name="name">Attendance: Close Old Pay Periods</field>
            <field name="model_id" ref="model_elksattendance_timecard_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_close_old_periods()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-05-02 05:30:00</field>
            <field name="active" eval="False"/>
            <field name="priority">48</field>
        </record>

        <!-- Daily cron that checks frequency settings and sends timecard
             email on the appropriate day.  Runs at 6:00 AM server time
             so the report is in the recipient's inbox before the workday. -->
        <record id="ir_cron_timecard_email" model="ir.cron">
            <field name="name">Attendance: Send Timecard Email</field>
            <field name="model_id" ref="model_elksattendance_timecard_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_timecard_email()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="nextcall">2026-05-02 06:00:00</field>
            <field name="active" eval="True"/>
            <field name="priority">50</field>
        </record>

        <!-- Daily cron: remind unapproved employees/approvers N days before
             the current pay period closes. -->
        <record id="ir_cron_approval_reminder" model="ir.cron">
            <field name="name">Attendance: Timecard Approval Reminders</field>
            <field name="model_id" ref="model_elksattendance_timecard_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_approval_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-05-02 07:00:00</field>
            <field name="active" eval="True"/>
            <field name="priority">52</field>
        </record>

        <!-- Hourly cron that flags employees still clocked in past the
             configured threshold (default 20h) as a possible missed
             clock-out, emailing the employee and their Attendance approver. -->
        <record id="ir_cron_long_shift_check" model="ir.cron">
            <field name="name">Attendance: Check for Missed Clock-Outs</field>
            <field name="model_id" ref="model_elksattendance_timecard_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_long_shifts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="nextcall">2026-05-02 06:30:00</field>
            <field name="active" eval="True"/>
            <field name="priority">55</field>
        </record>

    </data>
</odoo>

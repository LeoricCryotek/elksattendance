<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         === HUMAN ===
         Attendance list/form/search tweaks: tip columns and filters, plus a per-line
         Approve Timecard button that hides once the period is approved (locked).
         === AI AGENT ===
         Inherited views of core hr.attendance views. The form adds a <header> with
         the approve button bound to x_timecard_state (non-stored compute).
         ===================================================================== -->

    <!-- Add "Tipped Shift" column to the attendance list view -->
    <record id="view_attendance_tree_inherit_tips" model="ir.ui.view">
        <field name="name">hr.attendance.tree.tips</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">
            <field name="worked_hours" position="after">
                <field name="x_is_tipped_shift" optional="show"
                       widget="boolean_toggle"/>
                <field name="x_tip_amount" optional="show"
                       invisible="not x_is_tipped_shift"
                       readonly="not x_is_tipped_shift"/>
            </field>
        </field>
    </record>

    <!-- Add tip/gratuity fields to the attendance form view -->
    <record id="view_attendance_form_inherit_tips" model="ir.ui.view">
        <field name="name">hr.attendance.form.tips</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <field name="x_timecard_state" invisible="1"/>
                    <button name="action_elks_approve_timecard" type="object"
                            string="Approve Timecard" class="btn-primary"
                            invisible="x_timecard_state == 'approved'"
                            help="Approve this employee's pay-period timecard (supervisor / override)."/>
                    <span class="badge text-bg-success ms-2"
                          invisible="x_timecard_state != 'approved'">
                        Timecard Approved (locked)
                    </span>
                </header>
            </xpath>
            <group name="check_out_group" position="after">
                <separator string="Tips / Gratuity"
                           invisible="not x_is_tipped_shift"/>
                <group colspan="2" invisible="not x_is_tipped_shift">
                    <group>
                        <field name="x_is_tipped_shift" readonly="1"/>
                        <field name="x_tip_amount"/>
                    </group>
                </group>
            </group>
        </field>
    </record>

    <!-- Add "Tipped Shift" filter and group-by to the attendance search -->
    <record id="view_attendance_search_inherit_tips" model="ir.ui.view">
        <field name="name">hr.attendance.search.tips</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="filter_tipped" string="Tipped Shifts"
                        domain="[('x_is_tipped_shift', '=', True)]"/>
                <filter name="filter_not_tipped" string="Non-Tipped Shifts"
                        domain="[('x_is_tipped_shift', '=', False)]"/>
            </xpath>
        </field>
    </record>

</odoo>

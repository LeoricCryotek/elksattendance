<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         === HUMAN ===
         The Link Roles to Contact pop-up form and the Action-menu entry on the
         employee list that opens it.
         === AI AGENT ===
         Form view + act_window for elks.employee.link.wizard, bound to hr.employee
         via binding_model_id so it appears in the list/form Action menu.
         ===================================================================== -->

    <record id="view_elks_employee_link_wizard_form" model="ir.ui.view">
        <field name="name">elks.employee.link.wizard.form</field>
        <field name="model">elks.employee.link.wizard</field>
        <field name="arch" type="xml">
            <form string="Link to Shared Contact">
                <div class="alert alert-info" role="alert">
                    The selected employee records will all share one Work
                    Contact. One portal login for that contact can then review
                    and approve each role's timecard (Board, Kitchen, Bar…),
                    while each keeps its own pay rate and approver.
                </div>
                <group>
                    <field name="partner_id"
                           options="{'no_create_edit': True}"/>
                    <field name="employee_ids" widget="many2many_tags"/>
                    <field name="invite_portal"/>
                </group>
                <footer>
                    <button name="action_link" type="object" string="Link"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_elks_employee_link_wizard" model="ir.actions.act_window">
        <field name="name">Link to Shared Contact</field>
        <field name="res_model">elks.employee.link.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_view_types">list,form</field>
    </record>

</odoo>
